{
  "name": "bgmt",
  "version": "0.1.3",
  "description": "Bangumi Data Toolkit",
  "keywords": [
    "bangumi",
    "bgm"
  ],
  "homepage": "https://github.com/yjl9903/bgmx#readme",
  "bugs": {
    "url": "https://github.com/yjl9903/bgmx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yjl9903/bgmx.git"
  },
  "license": "MIT",
  "author": "XLor",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./cdn": "./dist/cdn.mjs",
    "./package.json": "./package.json"
  },
  "types": "dist/index.d.mts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "release": "release-it",
    "test": "vitest",
    "test:ci": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bgmc": "workspace:*",
    "simptrad": "^0.2.0"
  },
  "engines": {
    "node": ">=v24.0.0"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(bgmt): release v${version}",
      "tag": true,
      "tagName": "${npm.name}@${version}",
      "push": true
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "after:version": "pnpm run build",
      "before:init": "pnpm run build && pnpm run test:ci"
    }
  }
}
