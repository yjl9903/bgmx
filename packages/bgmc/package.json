{
  "name": "bgmc",
  "version": "0.1.1",
  "description": "Bangumi Client",
  "keywords": [
    "bangumi",
    "bgm"
  ],
  "homepage": "https://github.com/yjl9903/bgmx#readme",
  "bugs": {
    "url": "https://github.com/yjl9903/bgmx/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yjl9903/bgmx.git"
  },
  "license": "MIT",
  "author": "XLor",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.mjs",
      "require": "./dist/types.cjs"
    }
  },
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*",
        "./*"
      ]
    }
  },
  "bin": {
    "bgmc": "./cli.mjs"
  },
  "files": [
    "*.mjs",
    "bangumi",
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "prettier --write 'src/**/*.ts' 'test/**/*.ts'",
    "generate:types": "node ./scripts/generate-types.mjs && prettier --write ./src/types/types/index.ts",
    "release": "release-it",
    "test": "vitest",
    "test:ci": "vitest --run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "breadc": "^1.0.0-beta.14"
  },
  "devDependencies": {
    "js-yaml": "^4.1.1",
    "openapi-typescript": "^7.13.0"
  },
  "engines": {
    "node": ">=v20.8.0"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(bgmc): release v${version}",
      "tag": true,
      "tagName": "${npm.name}@${version}",
      "push": true
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "after:version": "pnpm run build",
      "before:init": "pnpm run build && pnpm run test:ci"
    }
  }
}
