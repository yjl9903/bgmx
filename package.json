{
  "name": "@bgmx/monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "bgmc": "tsx packages/bgmc/src/cli.ts",
    "bgmx": "tsx apps/bgmx/src/cli.ts",
    "build": "turbo run build",
    "deploy:bgmw": "pnpm -C apps/bgmw run deploy",
    "dev": "turbo run dev --parallel",
    "format": "turbo run format --parallel",
    "release:bgmc": "pnpm -C packages/bgmc release",
    "release:bgmt": "pnpm -C packages/bgmt release",
    "release:bgmx": "pnpm -C apps/bgmx release",
    "release:tmdbc": "pnpm -C packages/tmdbc release",
    "test:ci": "turbo run test:ci",
    "tmdbc": "tsx packages/tmdbc/src/cli.ts",
    "typecheck": "turbo run typecheck",
    "preversion": "turbo run test:ci",
    "postversion": "turbo run build"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260619.1",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^24.13.2",
    "bangumi-data": ">=0.3.209",
    "bumpp": "latest",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "prettier": "^3.8.4",
    "release-it": "^16.2.1",
    "rimraf": "^6.1.3",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  },
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=v24.0.0"
  }
}
