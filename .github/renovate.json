{
  "extends": ["github>yjl9903/renovate-config"],
  "baseBranchPatterns": ["dev", "main"],
  "packageRules": [
    {
      "matchBaseBranches": ["dev"],
      "matchPackageNames": ["bangumi-data"],
      "enabled": false
    },
    {
      "matchBaseBranches": ["main"],
      "matchPackageNames": ["!bangumi-data"],
      "enabled": false
    },
    {
      "matchBaseBranches": ["main"],
      "matchPackageNames": ["bangumi-data"],
      "automerge": true
    }
  ]
}
