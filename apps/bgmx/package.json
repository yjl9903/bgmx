{
  "name": "bgmx",
  "version": "0.0.3",
  "description": "Scraper for bgmd",
  "keywords": [
    "bgmd"
  ],
  "homepage": "https://github.com/yjl9903/bgmc#readme",
  "bugs": {
    "url": "https://github.com/yjl9903/bgmc/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yjl9903/bgmc.git"
  },
  "license": "MIT",
  "author": "XLor",
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    }
  },
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "bin": {
    "bgmx": "./cli.mjs"
  },
  "files": [
    "*.mjs",
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "prettier --write 'src/**/*.ts'",
    "release": "release-it"
  },
  "dependencies": {
    "@animegarden/client": "^0.5.3",
    "@breadc/color": "^1.0.0-beta.14",
    "@clack/prompts": "^1.2.0",
    "bangumi-data": ">=0.3.204",
    "bgmc": "workspace:*",
    "bgmt": "workspace:*",
    "breadc": "^1.0.0-beta.14",
    "consola": "^3.4.2",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.0",
    "fastest-levenshtein": "^1.0.16",
    "fs-extra": "^11.3.4",
    "jsdom": "^29.0.1",
    "p-limit": "7.3.0",
    "rimraf": "^6.1.3",
    "tmdbc": "workspace:*",
    "undici": "^8.0.1",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1"
  },
  "engines": {
    "node": ">=v20.8.0"
  },
  "release-it": {
    "git": {
      "commitMessage": "chore(bgmx): release v${version}",
      "tag": true,
      "tagName": "${npm.name}@${version}",
      "push": true
    },
    "npm": {
      "publish": false
    },
    "hooks": {
      "after:version": "pnpm run build",
      "before:init": "pnpm run build"
    }
  }
}
